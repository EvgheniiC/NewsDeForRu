APP_NAME=newsForGermanyRU-backend
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
DATABASE_URL=sqlite:///./news.db
RSS_FETCH_LIMIT=30
RSS_FEED_MAX_ATTEMPTS=3
RSS_FEED_RETRY_BASE_DELAY_SECONDS=0.5
OPENAI_REQUEST_RETRIES=1
# Multi-replica: enable on one instance/process only, or use cron/separate worker.
PIPELINE_SCHEDULER_ENABLED=false
# Hourly at :00 from START through END (inclusive), in TIMEZONE (e.g. 6–22 ≈ 06:00 … 22:00).
PIPELINE_SCHEDULE_START_HOUR=6
PIPELINE_SCHEDULE_END_HOUR=22
PIPELINE_SCHEDULE_TIMEZONE=Europe/Berlin
PIPELINE_TASK_SWALLOW_ERRORS=true

# Human-readable logs: prefix each line with [run_id=...] during a pipeline run.
LOG_PREFIX_RUN_ID_PLAIN=true
# Production: one JSON object per line (overrides plain prefix when true).
LOG_JSON=false

# Optional: Sentry DSN (empty = disabled).
SENTRY_DSN=
# Optional: expose GET /metrics for Prometheus (disable or protect in production).
PROMETHEUS_METRICS_ENABLED=false

# Read-only provenance API: GET /internal/provenance/by-raw/{id}, /by-processed/{id}
# Header: X-Internal-Api-Key. Store in secrets; empty = routes return 404 (feature off).
# Do not expose publicly without network controls.
PROVENANCE_API_KEY=

AUTO_PUBLISH_THRESHOLD=0.85

LLM_PROVIDER=stub
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Telegram: autopublished items in the pipeline, and the same channel when a moderator approves from the queue (immediate).
# Create a bot via @BotFather; chat_id = your user id or group id (see Telegram docs).
TELEGRAM_NOTIFICATIONS_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
